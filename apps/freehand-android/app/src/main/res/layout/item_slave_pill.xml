<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="28dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginEnd="@dimen/fh_space_xs"
    android:paddingHorizontal="@dimen/fh_space_sm"
    android:background="@drawable/bg_pill">

    <View
        android:id="@+id/pill_dot"
        android:layout_width="@dimen/fh_status_dot"
        android:layout_height="@dimen/fh_status_dot"
        android:background="@drawable/bg_status_dot" />

    <TextView
        android:id="@+id/pill_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/fh_space_xs"
        android:textSize="@dimen/fh_text_sm"
        android:textColor="@color/fh_text_secondary_light" />
</LinearLayout>
