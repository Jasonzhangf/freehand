<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/fh_space_sm"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/agent_row_avatar"
        android:layout_width="@dimen/fh_avatar_md"
        android:layout_height="@dimen/fh_avatar_md"
        android:gravity="center"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_avatar" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/fh_space_sm"
        android:orientation="vertical">

        <TextView
            android:id="@+id/agent_row_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/fh_text_base"
            android:textColor="@color/fh_text_primary_light" />

        <TextView
            android:id="@+id/agent_row_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/fh_text_xs"
            android:textColor="@color/fh_text_secondary_light" />
    </LinearLayout>

    <TextView
        android:id="@+id/agent_row_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:paddingHorizontal="@dimen/fh_space_sm"
        android:paddingVertical="2dp"
        android:textSize="@dimen/fh_text_xs"
        android:textColor="@color/fh_text_secondary_light" />
</LinearLayout>
