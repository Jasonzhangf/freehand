<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fh_bg_primary_light">

    <!-- 主体：竖向线性布局，顶栏+从站+对话+状态横幅+输入+底导 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <!-- 顶栏 -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fh_topbar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/fh_space_md"
            android:background="@color/fh_bg_secondary_light">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="@dimen/fh_touch_min"
                android:layout_height="@dimen/fh_touch_min"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_open"
                android:src="@drawable/ic_menu" />

            <!-- 当前 agent tile -->
            <LinearLayout
                android:id="@+id/agent_current"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/fh_space_sm"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/fh_space_sm"
                android:background="@drawable/bg_pill">

                <View
                    android:id="@+id/agent_current_avatar"
                    android:layout_width="@dimen/fh_avatar_sm"
                    android:layout_height="@dimen/fh_avatar_sm"
                    android:background="@drawable/bg_avatar" />

                <TextView
                    android:id="@+id/agent_current_avatar_text"
                    android:layout_width="@dimen/fh_avatar_sm"
                    android:layout_height="@dimen/fh_avatar_sm"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:text="FH"
                    android:translationX="-28dp" />

                <TextView
                    android:id="@+id/agent_current_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/fh_space_sm"
                    android:textSize="@dimen/fh_text_base"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="freehand"
                    android:textColor="@color/fh_text_primary_light" />

                <View
                    android:id="@+id/agent_current_dot"
                    android:layout_width="@dimen/fh_status_dot"
                    android:layout_height="@dimen/fh_status_dot"
                    android:layout_marginEnd="@dimen/fh_space_xs"
                    android:background="@drawable/bg_status_dot" />

                <TextView
                    android:id="@+id/agent_current_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/fh_text_xs"
                    android:textColor="@color/fh_text_secondary_light"
                    android:text="running" />
            </LinearLayout>

            <!-- slaves 概览 tile -->
            <LinearLayout
                android:id="@+id/agent_slaves"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="@dimen/fh_space_sm"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/fh_space_sm"
                android:background="@drawable/bg_pill">

                <TextView
                    android:layout_width="@dimen/fh_avatar_sm"
                    android:layout_height="@dimen/fh_avatar_sm"
                    android:gravity="center"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:text="SL"
                    android:background="@drawable/bg_avatar" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/fh_space_sm"
                    android:textSize="@dimen/fh_text_base"
                    android:textColor="@color/fh_text_primary_light"
                    android:text="slaves" />

                <View
                    android:layout_width="@dimen/fh_status_dot"
                    android:layout_height="@dimen/fh_status_dot"
                    android:layout_marginStart="@dimen/fh_space_sm"
                    android:background="@drawable/bg_status_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/fh_space_xs"
                    android:textSize="@dimen/fh_text_xs"
                    android:textColor="@color/fh_text_secondary_light"
                    android:text="2 busy" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fh_line_light" />

        <!-- 从站 strip：水平滚动 -->
        <HorizontalScrollView
            android:id="@+id/slave_strip_scroll"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fh_slave_strip_height"
            android:background="@color/fh_bg_primary_light"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/slave_strip"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/fh_space_md" />
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fh_line_light" />

        <!-- 对话区：RecyclerView 渲染 Turn 卡片 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/conv_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="@dimen/fh_space_md"
            android:overScrollMode="never" />

        <!-- 状态横幅：仅做实时提示，不写入 session -->
        <LinearLayout
            android:id="@+id/status_banner"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fh_status_banner_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/fh_space_md"
            android:background="@color/fh_accent_alpha15">

            <View
                android:id="@+id/status_banner_dot"
                android:layout_width="@dimen/fh_status_dot"
                android:layout_height="@dimen/fh_status_dot"
                android:background="@drawable/bg_status_dot" />

            <TextView
                android:id="@+id/status_banner_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/fh_space_sm"
                android:textSize="@dimen/fh_text_sm"
                android:textColor="@color/fh_accent"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/status_banner" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fh_line_light" />

        <!-- 输入栏 -->
        <LinearLayout
            android:id="@+id/inputbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:padding="@dimen/fh_space_sm"
            android:background="@color/fh_bg_primary_light">

            <EditText
                android:id="@+id/input_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="@dimen/fh_touch_min"
                android:maxLines="5"
                android:padding="@dimen/fh_space_sm"
                android:background="@drawable/bg_pill"
                android:textSize="@dimen/fh_text_base"
                android:hint="@string/input_hint"
                android:inputType="textCapSentences|textMultiLine" />

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="@dimen/fh_touch_min"
                android:layout_height="@dimen/fh_touch_min"
                android:layout_marginStart="@dimen/fh_space_sm"
                android:background="@drawable/bg_send_btn"
                android:contentDescription="@string/input_send"
                android:src="@drawable/ic_send" />
        </LinearLayout>

        <!-- 底导 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fh_line_light" />

        <LinearLayout
            android:id="@+id/bottomnav"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fh_bottomnav_height"
            android:orientation="horizontal"
            android:background="@color/fh_bg_primary_light">

            <LinearLayout
                android:id="@+id/tab_chat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/fh_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="@dimen/fh_text_xs"
                    android:textColor="@color/fh_accent"
                    android:text="@string/bottom_chat" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_agents"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_agents" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="@dimen/fh_text_xs"
                    android:textColor="@color/fh_text_secondary_light"
                    android:text="@string/bottom_agents" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="@dimen/fh_text_xs"
                    android:textColor="@color/fh_text_secondary_light"
                    android:text="@string/bottom_settings" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 抽屉遮罩 -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/fh_scrim"
        android:visibility="gone" />

    <!-- 抽屉：从右侧滑入 -->
    <LinearLayout
        android:id="@+id/drawer"
        android:layout_width="@dimen/fh_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@drawable/bg_drawer"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- 抽屉标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/fh_space_lg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/fh_text_lg"
                android:textStyle="bold"
                android:textColor="@color/fh_text_primary_light"
                android:text="@string/drawer_title" />

            <ImageButton
                android:id="@+id/btn_close_drawer"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/drawer_close"
                android:src="@drawable/ic_close" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fh_line_light" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Agent 切换 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/fh_space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/fh_text_xs"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:textColor="@color/fh_text_secondary_light"
                        android:text="@string/section_agents" />

                    <LinearLayout
                        android:id="@+id/agent_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fh_space_sm"
                        android:orientation="vertical" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/fh_line_light" />

                <!-- Session 快切 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/fh_space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/fh_text_xs"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:textColor="@color/fh_text_secondary_light"
                        android:text="@string/section_sessions" />

                    <LinearLayout
                        android:id="@+id/session_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fh_space_sm"
                        android:orientation="vertical" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/fh_line_light" />

                <!-- 快速操作 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/fh_space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/fh_text_xs"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:textColor="@color/fh_text_secondary_light"
                        android:text="@string/section_quick_actions" />

                    <LinearLayout
                        android:id="@+id/quick_actions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fh_space_sm"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- 抽屉底部主操作 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fh_line_light" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/fh_space_lg">

            <Button
                android:id="@+id/btn_new_session"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/action_new_session"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_switch_main"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/fh_space_sm"
                android:text="@string/action_switch_main"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <Button
                android:id="@+id/btn_view_failed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/fh_space_sm"
                android:text="@string/action_view_failed"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
