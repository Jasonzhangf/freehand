<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="@dimen/fh_space_sm"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/session_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/fh_text_base"
        android:textStyle="bold"
        android:textColor="@color/fh_text_primary_light" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/session_meta_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/fh_text_xs"
            android:textColor="@color/fh_text_secondary_light" />

        <TextView
            android:id="@+id/session_meta_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/fh_space_xs"
            android:textSize="@dimen/fh_text_xs"
            android:textColor="@color/fh_text_secondary_light" />

        <TextView
            android:id="@+id/session_meta_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/fh_space_xs"
            android:textSize="@dimen/fh_text_xs"
            android:textColor="@color/fh_text_secondary_light" />
    </LinearLayout>
</LinearLayout>
