<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="@dimen/fh_space_sm"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/action_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/fh_text_base"
        android:textColor="@color/fh_text_primary_light" />

    <TextView
        android:id="@+id/action_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="@dimen/fh_text_xs"
        android:textColor="@color/fh_text_secondary_light" />
</LinearLayout>
