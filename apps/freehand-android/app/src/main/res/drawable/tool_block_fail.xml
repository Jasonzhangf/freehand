<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/fh_radius_sm" />
            <solid android:color="@color/fh_bg_primary_light" />
            <stroke android:width="1dp" android:color="@color/fh_line_light" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/fh_status_error" />
        </shape>
    </item>
    <item android:left="3dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/fh_radius_sm" />
            <solid android:color="@color/fh_bg_primary_light" />
            <stroke android:width="1dp" android:color="@color/fh_line_light" />
        </shape>
    </item>
</layer-list>
