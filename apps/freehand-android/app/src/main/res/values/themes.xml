<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 浅色主题 -->
    <style name="Theme.Freehand.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/fh_accent</item>
        <item name="colorPrimaryDark">@color/fh_accent_dark</item>
        <item name="colorAccent">@color/fh_accent</item>
        <item name="android:windowBackground">@color/fh_bg_primary_light</item>
        <item name="android:statusBarColor">@color/fh_bg_secondary_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/fh_bg_primary_light</item>
    </style>

    <!-- 深色主题 -->
    <style name="Theme.Freehand.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/fh_accent</item>
        <item name="colorPrimaryDark">@color/fh_accent_dark</item>
        <item name="colorAccent">@color/fh_accent</item>
        <item name="android:windowBackground">@color/fh_bg_primary_dark</item>
        <item name="android:statusBarColor">@color/fh_bg_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/fh_bg_primary_dark</item>
    </style>

    <!-- 文本样式 -->
    <style name="TextAppearance.Freehand.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Freehand.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Freehand.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
    </style>
</resources>
